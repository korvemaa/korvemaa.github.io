---
import Image from "astro/components/Image.astro";
import { render } from "astro:content";

const { experience } = Astro.props;
const { Content } = await render(experience);

---

<div class="experience-bar">
    {
        experience.data.icon && (
            <Image
                width="64"
                src={experience.data.icon}
                alt={experience.data.name}
            />
        )
    }
    <div class="employment-text">
        <h3>
            {experience.data.name}
        </h3>
        <span>
            {experience.data.position}
        </span>
        <span>
        </span>
    </div>
</div>

<style>
    .experience-bar {
        display: flex;
        flex-direction: row;
        overflow: hidden;
        gap: 1rem;
    }

    .experience-bar img {
        width: 64px;
        height: 64px;
    }

    a {
        padding: 1rem;
        text-decoration: none;
    }

    a:hover {
        background-color: var(--dimmed-glow-color);
    }

    h3 {
        font-size: var(--font-size);
        margin-bottom: 0;
    }

    .employment-text {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .sub-text {
        opacity: 0.4;
    }

    .employment-about {
        margin: 1rem;
    }
</style>
